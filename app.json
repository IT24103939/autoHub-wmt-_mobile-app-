{
  "expo": {
    "name": "AutoHub",
    "slug": "autohub-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "sdkVersion": "54.0.0",
    "jsEngine": "hermes",
    "icon": "./assets/Gemini_Generated_Image_j41w25j41w25j41w.png",
    "splash": {
      "image": "./assets/Gemini_Generated_Image_j41w25j41w25j41w.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.anonymous.autohub",
      "adaptiveIcon": {
        "foregroundImage": "./assets/Gemini_Generated_Image_j41w25j41w25j41w.png",
        "backgroundColor": "#000000"
      },
      "queries": [
        {
          "intent": {
            "action": "android.intent.action.VIEW",
            "data": {
              "scheme": "geo"
            }
          }
        },
        {
          "intent": {
            "action": "android.intent.action.VIEW",
            "data": {
              "scheme": "https"
            }
          }
        },
        {
          "intent": {
            "action": "android.intent.action.VIEW",
            "data": {
              "scheme": "http"
            }
          }
        },
        {
          "intent": {
            "action": "android.intent.action.VIEW",
            "data": {
              "scheme": "mailto"
            }
          }
        }
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "01a92381-71c9-4b1a-80e7-1009760a5571"
      }
    }
  }
}
